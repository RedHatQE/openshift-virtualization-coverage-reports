# Create your secret from this template:
#   cp deploy/secret.yaml.example deploy/secret.yaml
#   # Fill in base64-encoded values
#   kubectl apply -f deploy/secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: coverage-reports-secrets
  labels:
    app: coverage-reports
type: Opaque
data:
  # base64-encode values: echo -n "value" | base64
  RP_URL: ""       # ReportPortal base URL
  RP_PROJECT: ""   # ReportPortal project name
  RP_TOKEN: ""     # ReportPortal API token
  GIT_TOKEN: ""    # Git token for private repos (optional)
